# Copia in .env e personalizza (il file .env non va committato).

# --- Produzione (obbligatorio in server) ---
DJANGO_SETTINGS_MODULE=settings_production
DJANGO_SECRET_KEY=genera-una-chiave-lunga-e-segreta

# Host e CSRF (opzionale: se vuoto, settings_production usa i default plazapretoria.it)
# GESPER_ALLOWED_HOSTS=gesper.esempio.it,www.esempio.it
# GESPER_CSRF_TRUSTED_ORIGINS=https://gesper.esempio.it,https://www.esempio.it

# Cache Redis per OTP registrazione candidati (consigliato con più worker Gunicorn)
# pip install redis
GESPER_REDIS_URL=redis://127.0.0.1:6379/1

# Log applicativo
# GESPER_LOG_FILE=/var/www/logs/gesper.log

# --- E-mail (fallback solo se SMTP non compilato in Admin → Configurazione di sistema) ---
# In produzione usare sempre l’admin GESPER per host, porta, utente, password, nome mittente.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=

# --- SMS Twilio (registrazione OTP) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+15017122661

# --- Web Push (override chiavi rispetto a settings.py) ---
# GESPER_VAPID_PUBLIC_KEY=
# GESPER_VAPID_PRIVATE_KEY=
# GESPER_VAPID_EMAIL=admin@tuodominio.it
