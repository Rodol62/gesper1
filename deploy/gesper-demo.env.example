# Copiare su VPS come /etc/gesper-demo.env (chmod 600) e adattare host/password.
# Secondo Gunicorn (gesper-demo.service) usa questo file: istanza DEMO separata da /etc/gesper.env.
#
# DNS: record A (o CNAME) demo.… → stessa VPS della produzione. Poi:
#   sudo certbot certonly --nginx -d demo.gesper1.plazapretoria.it
# (o integrazione con il vhost già presente).

DJANGO_SETTINGS_MODULE=settings_production
# Chiave dedicata (non riusare quella dell'operativo).
DJANGO_SECRET_KEY=GENERA_UNA_CHIAVE_LUNGA_DIVERSA_DALL_OPERATIVO

# --- Radice dati SOLO demo (mai la stessa di produzione) ---
GESPER_DATA_ROOT=/var/www/gesper-demo/documento

# Sandbox sempre attiva su questo processo (router + DB db_sandbox.sqlite3).
GESPER_SANDBOX_ENABLED=1
GESPER_SANDBOX_DEMO_PASSWORD=CambiaQuestaPasswordDemoForte!

# Opzionale: utenti dimostrativi multipli separati da virgola (minuscolo).
# GESPER_SANDBOX_USERNAMES=demo

# Host e CSRF solo per il sottodominio demo (obbligatori in produzione HTTPS).
GESPER_ALLOWED_HOSTS=demo.gesper1.plazapretoria.it
GESPER_CSRF_TRUSTED_ORIGINS=https://demo.gesper1.plazapretoria.it

# Redis: usare un DB logico diverso dall'operativo (es. /1 prod, /2 demo) per non mescolare OTP/cache.
GESPER_REDIS_URL=redis://127.0.0.1:6379/2

# Log separato (opzionale).
# GESPER_LOG_FILE=/var/www/gesper-demo/logs/gesper-demo.log

# db.sqlite3 (default) e db_sandbox.sqlite3 + media/ + media_sandbox/ vivono sotto GESPER_DATA_ROOT.
